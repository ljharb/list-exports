{
	"name": "list-exports-monorepo",
	"version": "0.1.0",
	"private": true,
	"description": "Given a package name and a version number, or a path to a package.json, what specifiers does it expose?",
	"scripts": {
		"version": "node release.mjs",
		"lint": "eslint .",
		"pretest": "npm run lint",
		"pretests-only": "npm run prepack -w ls-exports",
		"tests-only": "tape packages/tests",
		"tests:conditions": "tape packages/tests/conditions",
		"tests:conditions-option": "tape packages/tests/conditions-option.js",
		"test": "npm run tests-only && npm run tests:conditions && npm run tests:conditions-option",
		"posttest": "npx npm@'>=10.2' audit --production",
		"since": "node since"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ljharb/list-exports.git"
	},
	"directories": {
		"test": "packages/test"
	},
	"keywords": [
		"exports",
		"cjs",
		"esm",
		"module",
		"commonjs",
		"es",
		"export",
		"entrypoint",
		"resolve"
	],
	"author": "Jordan Harband <ljharb@gmail.com>",
	"funding": {
		"url": "https://github.com/sponsors/ljharb"
	},
	"devDependencies": {
		"@ljharb/eslint-config": "^22.2.3",
		"auto-changelog": "^2.6.0",
		"eslint": "^9.39.4",
		"evalmd": "^0.0.19",
		"glob-gitignore": "^1.0.15",
		"has-dynamic-import": "^2.1.1",
		"jiti": "^0.0.0",
		"ls-engines": "^0.10.1",
		"node-exports-info": "^1.6.0",
		"semver": "^7.8.5",
		"tape": "^5.10.2"
	},
	"engines": {
		"node": "^22.22 || ^24.13 || >=25.3"
	},
	"workspaces": [
		"packages/*"
	],
	"dependencies": {
		"@npmcli/arborist": "^9.2.0",
		"list-exports": "^2.2.0",
		"pacote": "^21.3.0"
	}
}
